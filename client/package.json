{
  "name": "hfrnet-client",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently 'npm:watch' 'npm:reload'",
    "watch": "nodemon --watch .env --watch ./www --ext js --ignore '*.min.js' --exec 'npm run minify'",
    "minify": "webpack",
    "reload": "browser-sync start --proxy 'hfrnet-php-server:80' --files '/app/**/*.*' --no-open --no-ui --host 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "dotenv-webpack": "^8.1.0",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4",
    "terser": "^5.36.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "browser-sync": "^2.29.3",
    "concurrently": "^8.2.0"
  }
}
